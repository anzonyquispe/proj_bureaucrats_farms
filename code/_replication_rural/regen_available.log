. ********************************************************************************
. * One-off helper: regenerates the tables whose ster files are present in the
. * local Dropbox mirror, mirroring the latest generator code (so they get the
. * trailing-zero strip too). Sections 3 and 4 (_main_4, _main_5) require ster
. * files that have not yet arrived from the cluster — they will pick up the
. * same formatting automatically once those ster files land.
. ********************************************************************************
. 
. clear all

. set more off

. 
. global location "dbox"

. global sample ""

. global shell "/groups/sgulzar/sa_fires/proj_bureaucrats_farms"

. global dbox "/Users/anzony.quisperojas/Library/CloudStorage/Dropbox/sa_fires/proj_bureaucrats_farms"

. global root "$dbox"

. global tables "${root}/tex/paper/tables"

. 
. * Pull in the strip-zeros helper from the main generator
. capture program drop _strip_zeros_stats

. program define _strip_zeros_stats
  1.     syntax , Models(string) Stats(string)
  2.     foreach m of local models {
  3.         capture estimates restore `m'
  4.         if _rc continue
  5.         foreach s of local stats {
  6.             local raw "`e(`s')'"
  7.             if "`raw'" == "" continue
  8.             local rnum = real("`raw'")
  9.             if !missing(`rnum') {
 10.                 local raw = strtrim(string(`rnum', "%9.3f"))
 11.             }
 12.             else {
 13.                 local raw = strtrim("`raw'")
 14.             }
 15.             local cleaned = regexr(regexr("`raw'", "0+$", ""), "\.$", "")
 16.             estadd local `s'_clean "`cleaned'"
 17.         }
 18.         estimates store `m'
 19.     }
 20. end

. 
