-------------+---------------------------------------------------------
relative_y~n |  6,179,629   -1.390609    1.420525         -4          1

. local rmin = r(min)

. gen post_ = relative_year_bin >= 0

. gen moderator = 0

. 
. local dep_var countk

. local rhs "ib0.post_##ib0.treat##ib0.downup_ac wind_direction av_wind_speed"

